PORT=8787
DATABASE_URL=

# ─── Paycrest (primary payout rail) ──────────────────────────────────────────
PAYCREST_MODE=mock            # "mock" for local dev, "live" for production
PAYCREST_API_KEY=
PAYCREST_BASE_URL=https://api.paycrest.io/v1
PAYCREST_WEBHOOK_SECRET=      # shared secret for webhook signature verification

# ─── Paystack (SUSPENDED) ────────────────────────────────────────────────────
# Paystack integration is currently paused. Do not set these for new deployments.
# PAYSTACK_SECRET_KEY=
# PAYSTACK_WEBHOOK_SECRET=

# ─── x402 / paid API access ───────────────────────────────────────────────────
THIRDWEB_SECRET_KEY=
X402_SERVER_WALLET=           # EVM wallet address that receives x402 payments
X402_NETWORK=celo             # "celo" | "base" | "celo-sepolia"
X402_PRICE_QUOTE=$0.001
X402_PRICE_PAYOUT=$0.02
X402_PRICE_LIQUIDITY=$0.005
X402_PRICE_SETTLEMENT=$0.005

# Internal bypass (owner/admin), optional
OWNER_API_KEY=

# ─── Deposit wallets ──────────────────────────────────────────────────────────
# Celo/Base: leave blank — Paycrest provides its own deposit address per order
DEPOSIT_WALLET_CELO=
DEPOSIT_WALLET_BASE=
# Stacks: principal of the deployed clova-deposit.clar contract
DEPOSIT_WALLET_STACKS=SP...clova-deposit

# Stacks reserve: USDC/Base wallet used to fund Paycrest orders for Stacks payouts
STACKS_RESERVE_WALLET=0x...

# ─── Stacks / USDCx ──────────────────────────────────────────────────────────
RPC_URL_STACKS=https://api.mainnet.hiro.so
# Override USDCx contract if using testnet
# USDCX_STACKS_CONTRACT=SP120SBRBQJ00MCWS7TM5R8WJNTTKD5K0HFRC2CNE.usdcx

# ─── Chain RPCs ──────────────────────────────────────────────────────────────
RPC_URL_CELO=
RPC_URL_BASE=
# Backward-compatible aliases:
CELO_RPC_URL=
BASE_RPC_URL=

# ─── Watcher auth + confirmation policy ──────────────────────────────────────
WATCHER_AUTH_TOKEN=
MIN_CONFIRMATIONS_CUSD_CELO=1
MIN_CONFIRMATIONS_USDC_BASE=1
MIN_CONFIRMATIONS_USDCX_STACKS=1
SETTLEMENT_PRECHECK_DELAY_MS=40000
SETTLEMENT_VERIFY_RETRY_DELAY_MS=15000
SETTLEMENT_VERIFY_MAX_ATTEMPTS=3

# ─── Order expiry worker ─────────────────────────────────────────────────────
ORDER_EXPIRY_MS=1800000         # 30 minutes
EXPIRY_CHECK_INTERVAL_MS=300000 # sweep every 5 minutes

# ─── Misc ────────────────────────────────────────────────────────────────────
DEFAULT_FEE_BPS=150
DEFAULT_NGN_RATE=1500
RATE_MARGIN_PCT=3
LOG_LEVEL=INFO
